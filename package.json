{
  "name": "admin",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev -p 4000",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "db:generate": "drizzle-kit generate",
    "db:push": "drizzle-kit push",
    "db:studio": "drizzle-kit studio",
    "gen:types": "npx supabase gen types typescript --project-id hkmkxkvrkfwgiutajvbf --schema public > src/types/database.types.ts",
    "db:setup": "drizzle-kit push --force && npx tsx scripts/fresh-db.ts",
    "db:setup:prod": "APP_ENV=production npx drizzle-kit push --force --config drizzle.config.ts && APP_ENV=production npx tsx --env-file=.env.production scripts/fresh-db.ts",
    "db:updates": "drizzle-kit push --force && npx tsx scripts/deploy-sql.ts",
    "db:migrate:prod": "npx drizzle-kit push --config drizzle.config.ts",
    "copy:table": "ts-node src/utils/dbMove.ts"
  },
  "dependencies": {
    "@radix-ui/react-switch": "^1.2.6",
    "@supabase/ssr": "^0.8.0",
    "@supabase/supabase-js": "^2.91.1",
    "@types/pg": "^8.16.0",
    "clsx": "^2.1.1",
    "dotenv": "^17.2.3",
    "drizzle-orm": "^0.45.1",
    "lucide-react": "^0.564.0",
    "next": "^16.2.0",
    "next-themes": "^0.4.6",
    "pg": "^8.18.0",
    "postgres": "^3.4.8",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.4.0"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "drizzle-kit": "^0.31.8",
    "eslint": "^9",
    "eslint-config-next": "16.1.4",
    "tailwindcss": "^4",
    "tsx": "^4.21.0",
    "typescript": "^5"
  }
}